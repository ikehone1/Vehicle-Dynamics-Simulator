        "#Newton Method\n",
        "def Newton(N_o, N, N_a):               # X_n+1 = X_n - f(X_n)/f'(X_n) -> vel/accel or pos/vel\n",
        "  N_next = N_o - (N / N_a)    # N_o is the initial guess\n",
        "                              # Have to solve f(X_n)=0\n",
        "  while N_next <= {N:.6}:\n",
        "    N_next = N - (N / N_a)\n",
        "    N = {N:.6}\n",
        "    N_next = {N_next:.6}\n",
        "  print(N_next)"
      ],

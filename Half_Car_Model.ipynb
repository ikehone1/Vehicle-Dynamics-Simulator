        "#Suspension Bounds\n",
        "def susp_bumper(z_s, z_uf, z_ur):  #trying to bound the car body and wheels together instead of having them separate.\n",
        "  #Ride Height\n",
        "  z_s += h              #for straight axle cars it's usually a 1:1 ratio of wheel movement to suspension travel but varies with independent lever-arm suspensions\n",
        "  susp_trav_F = z_s - (z_uf)\n",
        "  susp_trav_R = z_s - (z_ur)\n",
        "  if susp_trav_R > 0.1524:\n",
        "    #print(susp_trav_R)                          #0.1524 = 6 inches of travel for an average street car\n",
        "    susp_trav_R = 0.1524\n",
        "  if susp_trav_F > 0.1524:\n",
        "    #print(susp_trav_F)\n",
        "    susp_trav_F = 0.1524\n",
        "  if susp_trav_F < 0.0508:    #0.0508 = 2 inches for minimum suspension travel\n",
        "    susp_trav_F = 0.0508\n",
        "  if susp_trav_R < 0.0508:\n",
        "    susp_trav_R = 0.0508\n",
        "  z_uf = z_s - susp_trav_F\n",
        "  z_ur = z_s - susp_trav_R\n",
        "  return z_s, z_uf, z_ur, susp_trav_F, susp_trav_R"
      ],
      "metadata": {
        "id": "xC7uYd5iPU7H"
      },
      "execution_count": null,
      "outputs": []

      "source": [
        "#Car acceleration  a = F/m\n",
        "def HalfCar_Accel(z_s, z1_s, z_uf, z1_uf, z_ur, z1_ur, theta, theta1, A, w, delay, t):\n",
        "  #Road Input\n",
        "  z_rf = rand_roadinput(t)\n",
        "  z_rr = rand_roadinput(t-delay)\n",
        "  #Deflections\n",
        "  dsf = (z_s + (a*theta)) - z_uf\n",
        "  dsr = (z_s - (b*theta)) - z_ur\n",
        "  #Deflection Velocity\n",
        "  d1sf = (z1_s + a*theta1) - z1_uf\n",
        "  d1sr = (z1_s - b*theta1) - z1_ur\n",
        "  #Forces and Moments\n",
        "  F_sf = (k_sf*dsf) + (c_sf*d1sf)\n",
        "  F_sr = (k_sr*dsr) + (c_sr*d1sr)\n",
        "  Ma = F_sf * a\n",
        "  Mb = F_sr * b\n",
        "\n",
        "  #Inertia\n",
        "  Iyy = m_s*((a+b)**2)*0.2  #0.2 is scaling factor\n",
        "\n",
        "  #Spring_Front =\n",
        "\n",
        "\n",
        "\n",
        "  #Accelerations\n",
        "  a_s = ((-k_sf*(z_s - z_uf))-(k_sr*(z_s - z_ur))-(c_sf*(z1_s - z1_uf))-(c_sr*(z1_s - z1_ur))) / m_s\n",
        "  #a_s = 0.0\n",
        "  a_uf = ((k_sf*(z_s - z_uf)) + (c_sf*(z1_s - z1_uf)) - (k_tf*(z_uf - z_rf))) / m_uf\n",
        "  #a_uf = 0.0\n",
        "  a_ur = ((k_sr*(z_s - z_ur)) + (c_sr*(z1_s - z1_ur)) - (k_tr*(z_ur - z_rr))) / m_ur\n",
        "  #a_ur = 0.0\n",
        "  a_theta = (-a*(F_sf) + b*(F_sr)) / (Iyy)  #mass cancels out\n",
        "  #a_theta = 0.0\n",
        "  return a_s, a_uf, a_ur, a_theta\n",
        "\n",
        "a_s, a_uf, a_ur, a_theta = HalfCar_Accel(z_s, z1_s, z_uf, z1_uf, z_ur, z1_ur, theta, theta1, A, w, delay, t)"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "#Explicit Euler Solver\n",
        "t_eul = 0.0\n",
        "t_end = 3.0\n",
        "dt_e = 0.001\n",
        "z_s_e = 0.0\n",
        "z1_s_e = 0.0\n",
        "z_uf_e = 0.0\n",
        "z1_uf_e = 0.0\n",
        "z_ur_e = 0.0\n",
        "z1_ur_e = 0.0\n",
        "theta_e = 0.0\n",
        "theta1_e = 0.0\n",
        "zse = 0.0\n",
        "zufe = 0.0\n",
        "zure = 0.0\n",
        "\n",
        "#X_e = [z_s_e, z1_s_e, z_uf_e, z1_uf_e, z_ur_e, z1_ur_e, theta_e, theta1_e]\n",
        "\n",
        "Time_e = []\n",
        "Zs_e = []\n",
        "#Zse = []\n",
        "Zuf_e = []\n",
        "Zur_e = []\n",
        "Z1s_e = []\n",
        "Z1uf_e = []\n",
        "Z1ur_e = []\n",
        "Pitch_e = []\n",
        "Pitch_Vel_e = []\n",
        "Zrf_e = []\n",
        "Zrr_e = []\n",
        "Sus_F = []\n",
        "Sus_R = []\n",
        "Ase = []\n",
        "\n",
        "while t_eul < t_end:\n",
        "  #Acceleration Function\n",
        "  a_s_e, a_uf_e, a_ur_e, a_theta_e = HalfCar_Accel(z_s_e, z1_s_e, z_uf_e, z1_uf_e, z_ur_e, z1_ur_e, theta_e, theta1_e, A, w, delay, t_eul)\n",
        "  #Road Input\n",
        "  zrf_e = rand_roadinput(t_eul)\n",
        "  zrr_e = rand_roadinput(t_eul-delay)\n",
        "  #Velocities\n",
        "  z1_s_e += a_s_e * dt_e\n",
        "  z1_uf_e += a_uf_e * dt_e\n",
        "  z1_ur_e += a_ur_e * dt_e\n",
        "  theta1_e += a_theta_e * dt_e\n",
        "  #Positions\n",
        "  zse += z1_s_e * dt_e         #These positions need to be tied into the suspension travel\n",
        "  zufe += z1_uf_e * dt_e\n",
        "  zure += z1_ur_e * dt_e\n",
        "  theta_e += theta1_e * dt_e\n",
        "  #Suspension Travel\n",
        "  z_s_e, z_uf_e, z_ur_e, susp_trav_F, susp_trav_R = susp_bumper(zse, zufe, zure)\n",
        "  #Time\n",
        "  t_eul += dt_e\n",
        "\n",
        "  Time_e.append(t_eul)\n",
        "  Zs_e.append(z_s_e)\n",
        "  #Zse.append(zse)\n",
        "  Zuf_e.append(z_uf_e)\n",
        "  Zur_e.append(z_ur_e)\n",
        "  Z1s_e.append(z1_s_e)\n",
        "  Z1uf_e.append(z1_uf_e)\n",
        "  Z1ur_e.append(z1_ur_e)\n",
        "  Pitch_e.append(theta_e)\n",
        "  Pitch_Vel_e.append(theta1_e)\n",
        "  Zrf_e.append(zrf_e)\n",
        "  Zrr_e.append(zrr_e)\n",
        "  Sus_F.append(susp_trav_F)\n",
        "  Sus_R.append(susp_trav_R)\n",
        "  Ase.append(a_s_e)"
      ],
      "metadata": {

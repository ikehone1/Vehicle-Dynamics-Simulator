        "A_ur = []\n",
        "\n",
        "while t < t_end_rk4:\n",
        "  a_s, a_uf, a_ur, a_theta = HalfCar_Accel(z_s, z1_s, z_uf, z1_uf, z_ur, z1_ur, theta, theta1, A, w, delay, t)\n",
        "  z_s, z1_s, z_uf, z1_uf, z_ur, z1_ur, theta, theta1 = RK4_step(z_s, z1_s, z_uf, z1_uf, z_ur, z1_ur, theta, theta1, t)\n",

        "import csv\n",
        "filename = f\"HalfCar_Data1.csv\"\n",
        "with open(filename, \"w\", newline=\"\") as f:\n",
        "    writer = csv.writer(f)\n",
        "\n",
        "     #Header\n",
        "    writer.writerow([\n",
        "        \"Time_s\",\n",
        "        \"SprungMassPos_m\",\n",
        "        \"F_WheelPos_m\",\n",
        "        \"R_WheelPos_m\",\n",
        "        \"SprungVel\",\n",
        "        \"F_WheelVel\",\n",
        "        \"R_WheelVel\",\n",
        "        \"Pitch\",\n",
        "        \"PitchVel\",\n",
        "        \"RoadInput_m\",\n",
        "      ])\n",
        "\n",
        "    #Time History\n",
        "    for t, Z_s, Z_uf, Z_ur, Z1_s, Z1_uf, Z1_ur, Theta, ThetaVel, Z_r in zip(Time, Zs, Zuf, Zur, Z1s, Z1uf, Z1ur, Pitch, Pitch_Vel, Zr):\n",
        "       writer.writerow([t, Z_s, Z_uf, Z_ur, Z1_s, Z1_uf, Z1_ur, Theta, ThetaVel, Z_r])\n",
        "\n",
        "print(f'Saved {filename}')"
